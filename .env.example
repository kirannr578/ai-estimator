# Copy this file to `.env` and fill in the provider you intend to use.
# The app auto-detects which provider is configured.

# --- Anthropic (default, recommended for careful structured takeoffs) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI (alternative; faster / cheaper) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Pipeline tuning ---
# DPI used to render PDF pages for vision analysis. 200 is a good default;
# bump to 250-300 for very dense drawings, drop to 150 to save tokens.
RENDER_DPI=200

# Max parallel LLM calls (sheets analysed concurrently).
MAX_CONCURRENCY=4

# Default region cost multiplier (1.0 = national average).
REGION_MULTIPLIER=1.00

# --- CWICR cost-database tuning ---
# Region for CWICR cost lookups. The CWICR open dataset is shipped per-track;
# the bundled US variant is "usa_usd". This setting is reserved for future
# multi-track support — leave it as-is unless you swap to a different track.
CWICR_REGION=usa_usd
# Year ceiling for CWICR cost lookups. Uses the newest year <= this; leave
# blank for "newest available". The current dataset doesn't carry a year
# column, so this is effectively a no-op today, but kept for forward-compat.
CWICR_YEAR=
# Minimum similarity to accept a CWICR match. 0.55 is a balanced default;
# bump higher for stricter matching (fewer CWICR hits, more seed-DB fall-throughs).
CWICR_MIN_SIMILARITY=0.55
# Disable CWICR entirely and use the seed DB only. Accepts true/false/1/0.
CWICR_DISABLED=false

# --- Tier 1 pricing-data integrations ---
# All three keys are FREE with email registration. The refresh runner
# (scripts/refresh_pricing.py) auto-loads this file via python-dotenv.
# Sources whose key is blank are skipped at runtime with a warning.

# BLS public-data API. Without a key: 25 req/day (OK for ad-hoc dev).
# With a key: 500 req/day (required for the OEWS x 6 metros x 10 trades pull).
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# FRED (Federal Reserve Economic Data). Required for the FRED source.
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA petroleum / fuel prices. Required for the EIA source.
# Register at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=
