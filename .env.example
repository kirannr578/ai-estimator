# Copy this file to `.env` and fill in the provider you intend to use.
# The app auto-detects which provider is configured.

# --- Anthropic (default, recommended for careful structured takeoffs) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- OpenAI (alternative; faster / cheaper) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Pipeline tuning ---
# DPI used to render PDF pages for vision analysis. 200 is a good default;
# bump to 250-300 for very dense drawings, drop to 150 to save tokens.
RENDER_DPI=200

# Max parallel LLM calls (sheets analysed concurrently).
MAX_CONCURRENCY=4

# Default region cost multiplier (1.0 = national average).
REGION_MULTIPLIER=1.00
